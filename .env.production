# Used automatically for production builds (Netlify runs `npm run build`).
# The API URL is public (it ships in the browser bundle), so it is safe to commit.
# To repoint the frontend at a different backend, change this and redeploy,
# OR set REACT_APP_API_URL as an environment variable in Netlify (overrides this).
REACT_APP_API_URL=https://event-tracking-backend-jd70.onrender.com/api
